# Supabase project ref (course-sns: pbyxnvtgsrwmsvxnynif)
# See docs/HANDOFF.md for setup notes and Vercel checklist.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Naver Cloud Maps (required for map UI + driving directions) ---
NEXT_PUBLIC_NAVER_MAP_KEY=your-ncp-maps-client-id
NAVER_MAP_CLIENT_SECRET=your-ncp-maps-client-secret

# --- Naver Search OpenAPI (optional — place keyword search in RouteForm) ---
# Without these, search UI is hidden; other features work normally.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# --- TMAP OpenAPI (optional — real walking/cycling geometry on detail maps) ---
# Without this, pedestrian legs fall back to driving geometry or no line.
TMAP_APP_KEY=

# --- Site URL (optional — OG/Twitter absolute image URLs in production) ---
# Defaults to VERCEL_URL on Vercel, http://localhost:3000 locally.
NEXT_PUBLIC_SITE_URL=

# --- Playwright E2E (optional — defaults to seeded demo account) ---
E2E_DEMO_EMAIL=demo@course-sns.app
E2E_DEMO_PASSWORD=demo1234
